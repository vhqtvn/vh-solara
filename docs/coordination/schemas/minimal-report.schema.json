{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimal Coordination Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_type",
    "task_id",
    "session_alias",
    "status",
    "task_slice",
    "files_in_scope",
    "validation",
    "blockers",
    "recommended_next_prompt"
  ],
  "properties": {
    "report_type": {
      "const": "minimal"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "session_alias": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "partial"
      ]
    },
    "task_slice": {
      "type": "string",
      "minLength": 1
    },
    "files_in_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_next_prompt": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "path"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
