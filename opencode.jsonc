{
// vh-agent-harness :: opencode.jsonc (MANAGED)
// Generic agent/skill/permission wiring. Brand-free.
// - AGENTS: generic roles shipped under .opencode/agents/. Domain-specific
//   agents (e.g. auditors/builders tied to project components) live in the
//   project overlay.
// - instructions[]: keep minimal; project appends its own docs.
// - model refs use {file:./.local/config/agent-model/<name>} which is project-owned.
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "coordination",
    // MANAGED: instructions[] is config-driven. Harness keeps AGENTS.md + session-workflow
    // as the always-on context; project appends its own architecture/delivery/rule docs.
    "instructions": [
        "AGENTS.md",
        "docs/ai/opencode-session-workflow.md",
        // PROJECT: append project-specific docs here, e.g.:
        // "docs/ai/architecture-brief.md",
        // "docs/ai/delivery-rules.md",
    ],
    "share": "manual",
    "compaction": {
        "auto": true,
        "prune": true,
        "reserved": 12000,
    },
    "watcher": {
        "ignore": [
            ".opencode/state/**",
            ".opencode/scripts/__pycache__/**",
            ".pytest_cache/**",
            ".ruff_cache/**",
            "archives/**",
            "tmp/**",
        ],
    },
    "permission": {
        "edit": "ask",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow",
            "*.env.*.example": "allow",
        },
        "webfetch": "allow",
        "skill": {
            "*": "allow",
        },
        "bash": {
            "*": "deny",
            "jq *": "allow",
            "ls *": "allow",
            "rg *": "allow",
            "wc *": "allow",
            "cat *": "allow",
            "cut *": "allow",
            "date *": "allow",
            "echo *": "allow",
            "find *": "allow",
            "grep *": "allow",
            "head *": "allow",
            "sort *": "allow",
            "tail *": "allow",
            "true *": "allow",
            "uniq *": "allow",
            "sleep *": "allow",
            "uuidgen": "deny",
            "sed -n *": "allow",
            "git log *": "allow",
            "git diff *": "allow",
            "git grep *": "allow",
            "git show *": "allow",
            "git blame *": "allow",
            "git status *": "allow",
            "git ls-tree *": "allow",
            "git cat-file *": "allow",
            "git ls-files *": "allow",
            "git show-ref *": "allow",
            "git rev-parse *": "allow",
            "git check-ignore *": "allow",
            ".opencode/scripts/commit-gate.sh status": "deny",
            ".opencode/scripts/readonly-scripts.sh *": "allow",
            ".opencode/scripts/commit-gate.sh commit *": "deny",
            ".opencode/scripts/commit-gate.sh revert *": "deny",
            ".opencode/scripts/commit-gate.sh acquire *": "deny",
            ".opencode/scripts/commit-gate.sh release *": "deny",
            ".opencode/scripts/commit-gate.sh heartbeat *": "deny",
            ".opencode/scripts/commit-gate.sh stage-message *": "deny",
            "vh-agent-harness *": "allow",
        },
    },
    "agent": {
        "plan": {
            "mode": "subagent",
            "color": "info",
            "permission": {
                "edit": "deny",
                "webfetch": "allow",
                "skill": {
                    "*": "allow",
                },
                "bash": {
                    "*": "deny",
                    "jq *": "allow",
                    "ls *": "allow",
