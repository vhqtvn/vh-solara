# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
vh-solara

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# OS specific files
.DS_Store
.AppleDouble
.LSOverride

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.log

refs

# Repo-scoped agent/test artifacts (Playwright traces, reports, screenshots).
tmp/

# Node / web build artifacts. The built SPA (pkg/web/dist) is NOT committed — it's
# produced by `make web` locally and by the release workflow (GitHub Actions)
# before `go build`. A placeholder pkg/web/dist/index.html is kept so `//go:embed
# dist` and the Go tests compile without a frontend build. After `make web` the
# placeholder index.html is overwritten by the real shell; don't commit it.
node_modules/
web/test-results/
web/playwright-report/
pkg/web/dist/*
!pkg/web/dist/index.html

# Agent-local tooling / config.
.claude/

# vh-solara per-project local data (message attachments, etc.) is ignored, but
# the checked-in managed-project config (.vh-solara/project.jsonc) is NOT — it is
# meant to be committed so the repo can declare its companion processes/views.
.vh-solara/*
!.vh-solara/project.jsonc
# vh-agent-harness operator-local state (per-developer model overrides,
# coordinator runs, ssh, cleared-assumptions). NOT committed. The committed
# harness config lives under .vh-agent-harness/ and .opencode/.
.local/
